
# Environment variables for the application

LLM_PROVIDER=comet
COMET_API_KEY=<your_comet_api_key_here>

# Available COMET models:
COMET_MODEL=claude-opus-4-6
#COMET_MODEL=gpt-5.2
#COMET_MODEL=gemini-3-pro-all
#COMET_MODEL=chatgpt-4o-latest

# For LLM Studio, ensure that the URL points to the correct address where LLM Studio is running.
LM_STUDIO_URL=http://host.docker.internal:1234

# LangSmith API key for monitoring and logging LLM interactions
LANGSMITH_API_KEY=<your_langsmith_api_key_here>

# Input and output paths for the application
INPUT_ONTOLOGY_PATH=data/input/ontology.ttl
INPUT_CSV_PATH=data/input/weather_cleaned.csv

# Base URI for the ontology, used in RDF generation and SPARQL queries
BASE_URI=http://example.com/